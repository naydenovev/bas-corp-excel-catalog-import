// ВАЖНО: вся бизнес-логика реализована прямо в модуле формы (НЕ в модуле объекта,
// см. ОбъектМодуль), потому что в данной среде (BAF 8.3.23.2299, BAS Бухгалтерія КОРП,
// совместимость 8.3.12) вызов кастомных экспортных методов главного реквизита формы
// "Объект" у внешней обработки приводит к ошибке "Метод объекта не выявлено" —
// воспроизведено на минимальном тест-кейсе. Прямой вызов через
// ВнешниеОбработки.Создать(Путь).Метод() работает (используется в СведенияОВнешнейОбработке),
// поэтому логика формы вызывает собственные приватные процедуры/функции модуля формы.
//
// Процесс двухшаговый: «Проанализировать» читает файл и СТРОИТ ТаблицуАнализа без записи
// в базу (Статус: Можно создать / Можно обновить / Без изменений / Ошибка). Пользователь
// отмечает флажком «Обработать» нужные строки, затем «Создать» создаёт новые элементы,
// «Обновить» — обновляет найденные (с диалогом подтверждения расхождений по каждому).
//
// ВАЖНО: серверные переменные модуля формы (без привязки к реквизиту формы) НЕ сохраняются
// между нажатиями разных кнопок в данной среде (BAF) — проверено на практике. Поэтому
// «Создать» и «Обновить» каждый раз заново перечитывают файл (ПутьКФайлу/СпособЧтения —
// реквизиты формы, они сохраняются) и сверяются с уже посчитанным состоянием в реквизите
// формы ТаблицаАнализа (тоже сохраняется — это обычные данные формы, а не кэш в переменной).

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	СпособЧтения = "БезCOM";

	СписокВыбора = Элементы.ИмяСправочника.СписокВыбора;
	СписокВыбора.Очистить();
	Для Каждого МетаСправочник Из Метаданные.Справочники Цикл
		Если ПравоДоступа("Чтение", МетаСправочник) Тогда
			СписокВыбора.Добавить(МетаСправочник.Имя, МетаСправочник.Представление());
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ИмяСправочникаПриИзменении(Элемент)

	ТаблицаАнализа.Очистить();

	Если ПустаяСтрока(ИмяСправочника) Тогда
		ТаблицаСопоставления.Очистить();
		Возврат;
	КонецЕсли;

	ПостроитьТаблицуСопоставленияНаСервере(ИмяСправочника);

КонецПроцедуры

&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите файл данных";
	Диалог.Фильтр = "Файлы Excel (*.xlsx;*.xls;*.ods)|*.xlsx;*.xls;*.ods|Все файлы (*.*)|*.*";
	Диалог.МножественныйВыбор = Ложь;

	Если Диалог.Выбрать() Тогда
		ПутьКФайлу = Диалог.ПолноеИмяФайла;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Общая проверка готовности и чтение файла. Возвращает массив строк данных
// или Неопределено, если запуск невозможен (сообщение пользователю уже показано).
&НаКлиенте
Функция ПроверитьИПрочитатьФайл()

	Если ПустаяСтрока(ИмяСправочника) Тогда
		ПоказатьПредупреждение(, "Выберите вид справочника");
		Возврат Неопределено;
	КонецЕсли;

	Если ПустаяСтрока(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, "Выберите файл данных");
		Возврат Неопределено;
	КонецЕсли;

	Если СпособЧтения = "COMExcel" Тогда
		Попытка
			Строки = ПрочитатьЧерезCOMExcel(ПутьКФайлу);
		Исключение
			ПоказатьПредупреждение(, "Чтение через MS Excel недоступно (нужен толстый клиент с установленным MS Excel): "
				+ ОписаниеОшибки());
			Возврат Неопределено;
		КонецПопытки;
	Иначе
		Строки = ПрочитатьЧерезТабличныйДокумент(ПутьКФайлу);
	КонецЕсли;

	Если Строки.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "В файле нет строк данных (помимо заголовка)");
		Возврат Неопределено;
	КонецЕсли;

	Возврат Строки;

КонецФункции

// Шаг 1: читает файл и строит ТаблицуАнализа (без записи в базу).
&НаКлиенте
Процедура АнализироватьВыполнить(Команда)

	КлючевыеСтроки = ТаблицаСопоставления.НайтиСтроки(Новый Структура("КлючПоиска", Истина));
	Если ПустаяСтрока(ИмяСправочника) Тогда
		ПоказатьПредупреждение(, "Выберите вид справочника");
		Возврат;
	КонецЕсли;
	Если КлючевыеСтроки.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Отметьте хотя бы один реквизит как «Ключ поиска»");
		Возврат;
	КонецЕсли;

	Строки = ПроверитьИПрочитатьФайл();
	Если Строки = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Сводка = ПроанализироватьВсеНаСервере(ИмяСправочника, Строки);

	ПоказатьПредупреждение(, Сводка);

КонецПроцедуры

// Шаг 2а: перечитывает файл и создаёт новые элементы для строк ТаблицыАнализа со статусом
// «Можно создать» и отмеченным флажком «Обработать».
&НаКлиенте
Процедура СоздатьВыполнить(Команда)

	Если ТаблицаАнализа.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Сначала выполните анализ (кнопка «Проанализировать»)");
		Возврат;
	КонецЕсли;

	Строки = ПроверитьИПрочитатьФайл();
	Если Строки = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Результат = СоздатьВыбранныеНаСервере(ИмяСправочника, Строки);
	ПоказатьПредупреждение(, Результат);

КонецПроцедуры

// Шаг 2б: перечитывает файл, заново анализирует отмеченные строки со статусом «Можно
// обновить» и показывает ОДИН общий диалог со списком всех расхождений по всем элементам
// сразу (с флажком применения у каждой строки списка), затем применяет подтверждённое.
//
// ВАЖНО: в этой конфигурации модальные окна полностью запрещены (ИспользованиеМодальности =
// НеИспользовать) — это касается не только синхронных вызовов, но и Форма.ОткрытьМодально()
// даже через Асинх/Ждать (проверено на практике — предупреждение не пропадает). Поэтому
// диалог подтверждения открывается НЕМОДАЛЬНО (ОткрытьФорму без блокирующего режима окна),
// а продолжение обработки выполняется в процедуре-обработчике закрытия этой формы
// (ПослеЗакрытияПодтвержденияРасхожденийЗавершение), которой передаётся весь нужный контекст.
&НаКлиенте
Процедура ОбновитьВыполнить(Команда)

	СтрокиДляОбновления = ТаблицаАнализа.НайтиСтроки(Новый Структура("Статус, Обработать", "Можно обновить", Истина));
	Если СтрокиДляОбновления.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Нет отмеченных строк со статусом «Можно обновить»");
		Возврат;
	КонецЕсли;

	Строки = ПроверитьИПрочитатьФайл();
	Если Строки = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Свежий анализ каждой отмеченной строки + сбор всех расхождений в один общий список.
	АнализыПоСтрокам   = Новый Соответствие; // НомерСтроки -> АнализСтроки
	ДанныеПоСтрокам    = Новый Соответствие; // НомерСтроки -> СтрокаДанных
	ОбщийСписокРасхождений = Новый Массив;
	СчётчикПропущено   = 0;

	Для Каждого СтрокаТаблицы Из СтрокиДляОбновления Цикл
		Индекс = СтрокаТаблицы.СтрокаФайла - 2;
		Если Индекс < 0 ИЛИ Индекс >= Строки.Количество() Тогда
			Продолжить;
		КонецЕсли;
		СтрокаДанных = Строки[Индекс];

		АнализСтроки = ПроанализироватьСтроку(ИмяСправочника, СтрокаДанных);

		Если АнализСтроки.Статус <> "ЕстьРасхождения" Тогда
			// состояние базы поменялось с момента анализа — пропускаем строку как устаревшую
			ОбновитьСтрокуТаблицыПослеПовторногоАнализаНаКлиенте(СтрокаТаблицы, АнализСтроки);
			СчётчикПропущено = СчётчикПропущено + 1;
			Продолжить;
		КонецЕсли;

		АнализыПоСтрокам.Вставить(СтрокаТаблицы.СтрокаФайла, АнализСтроки);
		ДанныеПоСтрокам.Вставить(СтрокаТаблицы.СтрокаФайла, СтрокаДанных);

		Для Каждого Расхождение Из АнализСтроки.Расхождения Цикл
			ОбщаяЗапись = Новый Структура;
			ОбщаяЗапись.Вставить("СтрокаФайла",    СтрокаТаблицы.СтрокаФайла);
			ОбщаяЗапись.Вставить("Элемент",        СтрокаТаблицы.Ключ);
			ОбщаяЗапись.Вставить("ИмяРеквизита",   Расхождение.ИмяРеквизита);
			ОбщаяЗапись.Вставить("Представление",  Расхождение.Представление);
			ОбщаяЗапись.Вставить("ЗначениеВБазе",  Расхождение.ЗначениеВБазе);
			ОбщаяЗапись.Вставить("ЗначениеВФайле", Расхождение.ЗначениеВФайле);
			ОбщийСписокРасхождений.Добавить(ОбщаяЗапись);
		КонецЦикла;
	КонецЦикла;

	Если ОбщийСписокРасхождений.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Обновлено: 0. Пропущено: " + СчётчикПропущено + ". Ошибок: 0");
		Возврат;
	КонецЕсли;

	КонтекстПродолжения = Новый Структура("АнализыПоСтрокам, ДанныеПоСтрокам, СчётчикПропущено",
		АнализыПоСтрокам, ДанныеПоСтрокам, СчётчикПропущено);

	ПараметрыОткрытия = Новый Структура("Расхождения", ОбщийСписокРасхождений);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияПодтвержденияРасхожденийЗавершение",
		ЭтотОбъект, КонтекстПродолжения);

	ОткрытьФорму("ВнешняяОбработка.ЗагрузкаСправочникаИзExcel.Форма.ФормаПодтверждения",
		ПараметрыОткрытия, ЭтотОбъект, , , , ОписаниеОповещения);

КонецПроцедуры

// Вызывается платформой после закрытия немодальной формы подтверждения расхождений
// (см. ОбновитьВыполнить). ОтмеченныеЗаписи — результат, переданный формой через
// Закрыть(...): массив структур {СтрокаФайла, ИмяРеквизита} либо Неопределено.
&НаКлиенте
Процедура ПослеЗакрытияПодтвержденияРасхожденийЗавершение(ОтмеченныеЗаписи, КонтекстПродолжения) Экспорт

	АнализыПоСтрокам = КонтекстПродолжения.АнализыПоСтрокам;
	ДанныеПоСтрокам  = КонтекстПродолжения.ДанныеПоСтрокам;
	СчётчикПропущено = КонтекстПродолжения.СчётчикПропущено;

	// Группируем подтверждённые записи по строке файла: НомерСтроки -> Массив имён реквизитов.
	ПодтверждённыеПоСтрокам = Новый Соответствие;
	Если ОтмеченныеЗаписи <> Неопределено Тогда
		Для Каждого Запись Из ОтмеченныеЗаписи Цикл
			СписокРеквизитов = ПодтверждённыеПоСтрокам.Получить(Запись.СтрокаФайла);
			Если СписокРеквизитов = Неопределено Тогда
				СписокРеквизитов = Новый Массив;
				ПодтверждённыеПоСтрокам.Вставить(Запись.СтрокаФайла, СписокРеквизитов);
			КонецЕсли;
			СписокРеквизитов.Добавить(Запись.ИмяРеквизита);
		КонецЦикла;
	КонецЕсли;

	СчётчикОбновлено = 0;
	СчётчикОшибок    = 0;

	Для Каждого Эл Из АнализыПоСтрокам Цикл
		НомерСтроки  = Эл.Ключ;
		АнализСтроки = Эл.Значение;
		СтрокаДанных = ДанныеПоСтрокам.Получить(НомерСтроки);
		ПодтверждённыеРеквизиты = ПодтверждённыеПоСтрокам.Получить(НомерСтроки);

		РезультатПрименения = ПрименитьОбновлениеНаСервере(НомерСтроки, ИмяСправочника,
			СтрокаДанных, АнализСтроки, ПодтверждённыеРеквизиты);

		Если РезультатПрименения = "Обновлён" Тогда
			СчётчикОбновлено = СчётчикОбновлено + 1;
		ИначеЕсли РезультатПрименения = "Пропущен" Тогда
			СчётчикПропущено = СчётчикПропущено + 1;
		Иначе
			СчётчикОшибок = СчётчикОшибок + 1;
		КонецЕсли;
	КонецЦикла;

	ПоказатьПредупреждение(, "Обновлено: " + СчётчикОбновлено + ". Пропущено: " + СчётчикПропущено
		+ ". Ошибок: " + СчётчикОшибок);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтрокуТаблицыПослеПовторногоАнализаНаКлиенте(СтрокаТаблицы, АнализСтроки)

	Если АнализСтроки.Статус = "БезИзменений" Тогда
		СтрокаТаблицы.Статус = "Без изменений";
	ИначеЕсли АнализСтроки.Статус = "Создать" Тогда
		СтрокаТаблицы.Статус = "Можно создать";
	Иначе
		СтрокаТаблицы.Статус = "Ошибка";
		СтрокаТаблицы.Детали = АнализСтроки.ОписаниеОшибки;
	КонецЕсли;
	СтрокаТаблицы.Обработать = Ложь;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОповещений

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// --- Построение карты реквизитов -------------------------------------------------

&НаСервере
Процедура ПостроитьТаблицуСопоставленияНаСервере(ИмяСправочникаЗначение)

	НоваяКарта = ПостроитьКартуРеквизитов(ИмяСправочникаЗначение);

	ТаблицаСопоставления.Очистить();
	Для Каждого СтрокаИсточник Из НоваяКарта Цикл
		НоваяСтрока = ТаблицаСопоставления.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточник);
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ПостроитьКартуРеквизитов(ИмяСправочника)

	РезультатТаблица = Новый ТаблицаЗначений;
	РезультатТаблица.Колонки.Добавить("ИмяРеквизита");
	РезультатТаблица.Колонки.Добавить("Представление");
	РезультатТаблица.Колонки.Добавить("ИмяТабличнойЧасти");
	РезультатТаблица.Колонки.Добавить("ТипРеквизита");
	РезультатТаблица.Колонки.Добавить("КолонкаФайла");
	РезультатТаблица.Колонки.Добавить("ПоУмолчанию");
	РезультатТаблица.Колонки.Добавить("КлючПоиска");

	МетаОбъект = Метаданные.Справочники.Найти(ИмяСправочника);
	Если МетаОбъект = Неопределено Тогда
		ВызватьИсключение "Справочник """ + ИмяСправочника + """ не найден в конфигурации";
	КонецЕсли;

	ДобавитьСтрокуКарты(РезультатТаблица, "Код", "Код", "", "Простой");
	ДобавитьСтрокуКарты(РезультатТаблица, "Наименование", "Наименование", "", "Простой");

	Если МетаОбъект.Иерархический Тогда
		ДобавитьСтрокуКарты(РезультатТаблица, "Родитель", "Родитель", "", "Родитель." + ИмяСправочника);
	КонецЕсли;

	Для Каждого Реквизит Из МетаОбъект.Реквизиты Цикл
		ДобавитьСтрокуКарты(РезультатТаблица, Реквизит.Имя, Реквизит.Синоним, "", КлассифицироватьТип(Реквизит.Тип));
	КонецЦикла;

	Для Каждого ТабЧасть Из МетаОбъект.ТабличныеЧасти Цикл
		Для Каждого РеквизитТЧ Из ТабЧасть.Реквизиты Цикл
			ДобавитьСтрокуКарты(РезультатТаблица, РеквизитТЧ.Имя, РеквизитТЧ.Синоним, ТабЧасть.Имя,
				"ТЧ." + КлассифицироватьТип(РеквизитТЧ.Тип));
		КонецЦикла;
	КонецЦикла;

	Возврат РезультатТаблица;

КонецФункции

&НаСервере
Процедура ДобавитьСтрокуКарты(Таблица, ИмяРеквизита, Представление, ИмяТабличнойЧасти, ТипРеквизита)

	Если ПустаяСтрока(Представление) Тогда
		Представление = ИмяРеквизита;
	КонецЕсли;

	НоваяСтрока = Таблица.Добавить();
	НоваяСтрока.ИмяРеквизита        = ИмяРеквизита;
	НоваяСтрока.Представление       = Представление;
	НоваяСтрока.ИмяТабличнойЧасти   = ИмяТабличнойЧасти;
	НоваяСтрока.ТипРеквизита        = ТипРеквизита;
	НоваяСтрока.КолонкаФайла        = "";
	НоваяСтрока.ПоУмолчанию         = "";
	НоваяСтрока.КлючПоиска          = Ложь;

КонецПроцедуры

// "Простой" — примитивный тип (строка/число/дата/булево и др.);
// "Ссылка.<ИмяСправочника>" — реквизит ссылается на справочник;
// "Перечисление.<ИмяПеречисления>" — реквизит типа Перечисление.
&НаСервере
Функция КлассифицироватьТип(ОписаниеТипов)

	Для Каждого Тип Из ОписаниеТипов.Типы() Цикл
		МетаОбъектТипа = Метаданные.НайтиПоТипу(Тип);
		Если МетаОбъектТипа = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Если Метаданные.Справочники.Содержит(МетаОбъектТипа) Тогда
			Возврат "Ссылка." + МетаОбъектТипа.Имя;
		ИначеЕсли Метаданные.Перечисления.Содержит(МетаОбъектТипа) Тогда
			Возврат "Перечисление." + МетаОбъектТипа.Имя;
		КонецЕсли;
	КонецЦикла;

	Возврат "Простой";

КонецФункции

// --- Чтение исходного файла --------------------------------------------------------

// Читает файл без COM: передаёт двоичные данные с клиента во временное хранилище сервера,
// сервер сохраняет во временный файл (с исходным расширением) и читает через ТабличныйДокумент.
&НаКлиенте
Функция ПрочитатьЧерезТабличныйДокумент(Путь)

	ДвоичныеДанные = Новый ДвоичныеДанные(Путь);
	АдресВХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные, ЭтотОбъект.УникальныйИдентификатор);

	ЧастиИмени = СтрРазделить(Путь, ".", Истина);
	Если ЧастиИмени.Количество() > 1 Тогда
		Расширение = "." + ЧастиИмени[ЧастиИмени.ВГраница()];
	Иначе
		Расширение = ".xlsx";
	КонецЕсли;

	Возврат ПрочитатьФайлТабличныйДокументНаСервере(АдресВХранилище, Расширение);

КонецФункции

&НаСервере
Функция ПрочитатьФайлТабличныйДокументНаСервере(АдресВХранилище, Расширение)

	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла(Расширение);
	ДвоичныеДанные.Записать(ИмяВременногоФайла);

	Попытка
		Результат = ПрочитатьФайлТабличныйДокумент(ИмяВременногоФайла);
	Исключение
		Попытка
			УдалитьФайлы(ИмяВременногоФайла);
		Исключение
		КонецПопытки;
		ВызватьИсключение;
	КонецПопытки;

	Попытка
		УдалитьФайлы(ИмяВременногоФайла);
	Исключение
	КонецПопытки;

	Возврат Результат;

КонецФункции

// Читает табличный документ (xlsx/ods/xls) без COM. Первая строка — заголовки колонок.
// Возвращает массив соответствий, где каждое значение доступно ОБОИМИ ключами:
// буквенным кодом колонки ("A", "B"...) и текстом заголовка (если он заполнен) —
// в форме «Колонка файла» можно указывать любой из двух вариантов.
&НаСервере
Функция ПрочитатьФайлТабличныйДокумент(ПутьКФайлу)

	Таб = Новый ТабличныйДокумент;
	Таб.Прочитать(ПутьКФайлу);

	КоличествоСтрок   = Таб.ВысотаТаблицы;
	КоличествоКолонок = Таб.ШиринаТаблицы;

	Если КоличествоСтрок < 2 Тогда
		Возврат Новый Массив;
	КонецЕсли;

	БуквыКолонок = Новый Массив;
	Заголовки    = Новый Массив;
	Для Ном = 1 По КоличествоКолонок Цикл
		БуквыКолонок.Добавить(КодКолонкиСервер(Ном));
		Заголовки.Добавить(СокрЛП(Таб.Область(1, Ном, 1, Ном).Текст));
	КонецЦикла;

	Результат = Новый Массив;
	Для НомерСтроки = 2 По КоличествоСтрок Цикл
		СтрокаДанных = Новый Соответствие;
		ЕстьЗначения = Ложь;
		Для Ном = 1 По КоличествоКолонок Цикл
			Значение = СокрЛП(Таб.Область(НомерСтроки, Ном, НомерСтроки, Ном).Текст);
			СтрокаДанных.Вставить(БуквыКолонок[Ном - 1], Значение);
			Если Не ПустаяСтрока(Заголовки[Ном - 1]) И Заголовки[Ном - 1] <> БуквыКолонок[Ном - 1] Тогда
				СтрокаДанных.Вставить(Заголовки[Ном - 1], Значение);
			КонецЕсли;
			Если Не ПустаяСтрока(Значение) Тогда
				ЕстьЗначения = Истина;
			КонецЕсли;
		КонецЦикла;
		Если Не ЕстьЗначения Тогда
			// ВысотаТаблицы у ТабличныйДокумент.Прочитать() может отражать использованную
			// область листа (с форматированием), а не реальные данные — останавливаемся
			// на первой полностью пустой строке, чтобы не читать «хвост» из файла.
			Прервать;
		КонецЕсли;
		Результат.Добавить(СтрокаДанных);
	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаСервере
Функция КодКолонкиСервер(Номер)

	Код = "";
	N = Номер;
	Пока N > 0 Цикл
		Остаток = (N - 1) % 26;
		Код = Символ(КодСимвола("A") + Остаток) + Код;
		N = Цел((N - 1) / 26);
	КонецЦикла;

	Возврат Код;

КонецФункции

// Читает файл через COM Excel.Application — только толстый клиент. Процесс Excel
// в любом случае (включая исключение) принудительно завершается через Quit().
&НаКлиенте
Функция ПрочитатьЧерезCOMExcel(Путь)

	Попытка
		Excel = Новый COMОбъект("Excel.Application");
	Исключение
		ВызватьИсключение "Не удалось запустить MS Excel: " + ОписаниеОшибки();
	КонецПопытки;

	Результат = Новый Массив;
	Книга = Неопределено;

	Попытка
		Excel.Visible = Ложь;
		Excel.DisplayAlerts = Ложь;
		Книга = Excel.Workbooks.Open(Путь);
		Лист = Книга.Worksheets(1);

		КоличествоСтрок   = Лист.UsedRange.Rows.Count;
		КоличествоКолонок = Лист.UsedRange.Columns.Count;

		БуквыКолонок = Новый Массив;
		Заголовки    = Новый Массив;
		Для Ном = 1 По КоличествоКолонок Цикл
			БуквыКолонок.Добавить(КодКолонкиExcel(Ном));
			// .Text (не .Value!) — иначе Excel может вернуть число/дату вместо текста
			// для ячеек с автоформатированием (например, код вида "00-00011294").
			Заголовки.Добавить(СокрЛП(Лист.Cells(1, Ном).Text));
		КонецЦикла;

		Для НомерСтроки = 2 По КоличествоСтрок Цикл
			СтрокаДанных = Новый Соответствие;
			ЕстьЗначения = Ложь;
			Для Ном = 1 По КоличествоКолонок Цикл
				ЗначениеСтрокой = СокрЛП(Лист.Cells(НомерСтроки, Ном).Text);
				СтрокаДанных.Вставить(БуквыКолонок[Ном - 1], ЗначениеСтрокой);
				Если Не ПустаяСтрока(Заголовки[Ном - 1]) И Заголовки[Ном - 1] <> БуквыКолонок[Ном - 1] Тогда
					СтрокаДанных.Вставить(Заголовки[Ном - 1], ЗначениеСтрокой);
				КонецЕсли;
				Если Не ПустаяСтрока(ЗначениеСтрокой) Тогда
					ЕстьЗначения = Истина;
				КонецЕсли;
			КонецЦикла;
			Если Не ЕстьЗначения Тогда
				// UsedRange может быть шире реальных данных (форматирование, шаблоны печати) —
				// останавливаемся на первой полностью пустой строке.
				Прервать;
			КонецЕсли;
			Результат.Добавить(СтрокаДанных);
		КонецЦикла;

		Книга.Close(Ложь);
		Excel.Quit();
	Исключение
		Попытка
			Если Книга <> Неопределено Тогда
				Книга.Close(Ложь);
			КонецЕсли;
		Исключение
		КонецПопытки;
		Excel.Quit();
		Excel = Неопределено;
		ВызватьИсключение "Ошибка чтения файла через MS Excel: " + ОписаниеОшибки();
	КонецПопытки;

	Excel = Неопределено;
	Возврат Результат;

КонецФункции

&НаКлиенте
Функция КодКолонкиExcel(Номер)

	Код = "";
	N = Номер;
	Пока N > 0 Цикл
		Остаток = (N - 1) % 26;
		Код = Символ(КодСимвола("A") + Остаток) + Код;
		N = Цел((N - 1) / 26);
	КонецЦикла;

	Возврат Код;

КонецФункции

// --- Анализ (шаг 1): построение ТаблицыАнализа без записи в базу -------------------

// Анализирует все строки файла (поиск элемента, расхождения), заполняет ТаблицуАнализа
// и возвращает текстовую сводку для пользователя.
&НаСервере
Функция ПроанализироватьВсеНаСервере(ИмяСправочникаЗначение, Строки)

	ТаблицаАнализа.Очистить();

	СчётчикСоздать    = 0;
	СчётчикОбновить   = 0;
	СчётчикБезИзменений = 0;
	СчётчикОшибок     = 0;
	Индекс            = 0;

	Для Каждого СтрокаДанных Из Строки Цикл

		НомерСтроки = Индекс + 2;
		АнализСтроки = ПроанализироватьСтроку(ИмяСправочникаЗначение, СтрокаДанных);

		НоваяСтрока = ТаблицаАнализа.Добавить();
		НоваяСтрока.СтрокаФайла = НомерСтроки;
		Если АнализСтроки.Ссылка <> Неопределено Тогда
			НоваяСтрока.Ключ = Строка(АнализСтроки.Ссылка);
		Иначе
			НоваяСтрока.Ключ = "(новый)";
		КонецЕсли;

		Если АнализСтроки.Статус = "Ошибка" Тогда
			НоваяСтрока.Статус = "Ошибка";
			НоваяСтрока.Детали = АнализСтроки.ОписаниеОшибки;
			НоваяСтрока.Обработать = Ложь;
			СчётчикОшибок = СчётчикОшибок + 1;
		ИначеЕсли АнализСтроки.Статус = "Создать" Тогда
			НоваяСтрока.Статус = "Можно создать";
			НоваяСтрока.Обработать = Истина;
			СчётчикСоздать = СчётчикСоздать + 1;
		ИначеЕсли АнализСтроки.Статус = "БезИзменений" Тогда
			НоваяСтрока.Статус = "Без изменений";
			НоваяСтрока.Обработать = Ложь;
			СчётчикБезИзменений = СчётчикБезИзменений + 1;
		ИначеЕсли АнализСтроки.Статус = "ЕстьРасхождения" Тогда
			НоваяСтрока.Статус = "Можно обновить";
			СписокИмён = Новый Массив;
			Для Каждого Расхождение Из АнализСтроки.Расхождения Цикл
				СписокИмён.Добавить(Расхождение.Представление);
			КонецЦикла;
			НоваяСтрока.Детали = СтрСоединить(СписокИмён, ", ");
			НоваяСтрока.Обработать = Истина;
			СчётчикОбновить = СчётчикОбновить + 1;
		КонецЕсли;

		Индекс = Индекс + 1;
	КонецЦикла;

	Возврат "Анализ завершён. Можно создать: " + СчётчикСоздать + ". Можно обновить: " + СчётчикОбновить
		+ ". Без изменений: " + СчётчикБезИзменений + ". Ошибок: " + СчётчикОшибок;

КонецФункции

&НаСервере
Функция ПроанализироватьСтроку(ИмяСправочникаЗначение, СтрокаДанных)

	Результат = Новый Структура("Статус, Ссылка, Расхождения, ОписаниеОшибки",
		"Ошибка", Неопределено, Новый Массив, "");

	КлючевыеСтроки = ТаблицаСопоставления.НайтиСтроки(Новый Структура("КлючПоиска", Истина));
	Если КлючевыеСтроки.Количество() = 0 Тогда
		Результат.ОписаниеОшибки = "Не указан ключ поиска";
		Возврат Результат;
	КонецЕсли;

	УсловияПоиска = Новый Структура;
	Для Каждого СтрокаКлюч Из КлючевыеСтроки Цикл
		Если Не ПустаяСтрока(СтрокаКлюч.ИмяТабличнойЧасти) Тогда
			Результат.ОписаниеОшибки = "Реквизит табличной части не может быть ключом поиска: "
				+ СтрокаКлюч.Представление;
			Возврат Результат;
		КонецЕсли;

		ТекстЗначения = СтрокаДанных.Получить(СтрокаКлюч.КолонкаФайла);
		Если ПустаяСтрока(СтрокаКлюч.КолонкаФайла) ИЛИ ТекстЗначения = Неопределено
				ИЛИ ПустаяСтрока(ТекстЗначения) Тогда
			Результат.ОписаниеОшибки = "Не заполнено значение ключа """ + СтрокаКлюч.Представление
				+ """ в строке файла";
			Возврат Результат;
		КонецЕсли;

		ЗначениеКлюча = РазрешитьЗначение(ИмяСправочникаЗначение, "", СтрокаКлюч.ИмяРеквизита,
			СтрокаКлюч.ТипРеквизита, ТекстЗначения);
		Если ЗначениеКлюча = Неопределено Тогда
			Результат.ОписаниеОшибки = "Не удалось разрешить значение ключа """
				+ СтрокаКлюч.Представление + """: " + ТекстЗначения;
			Возврат Результат;
		КонецЕсли;

		УсловияПоиска.Вставить(СтрокаКлюч.ИмяРеквизита, ЗначениеКлюча);
	КонецЦикла;

	Ссылка = НайтиЭлементПоУсловиям(ИмяСправочникаЗначение, УсловияПоиска);

	Если Ссылка = Неопределено Тогда
		Результат.Статус = "Создать";
		Возврат Результат;
	КонецЕсли;

	Расхождения = ПолучитьРасхождения(Ссылка, ИмяСправочникаЗначение, СтрокаДанных);

	Если Расхождения.Количество() = 0 Тогда
		Результат.Статус = "БезИзменений";
		Результат.Ссылка = Ссылка;
	Иначе
		Результат.Статус     = "ЕстьРасхождения";
		Результат.Ссылка     = Ссылка;
		Результат.Расхождения = Расхождения;
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаСервере
Функция НайтиЭлементПоУсловиям(ИмяСправочника, УсловияПоиска)

	Условия = Новый Массив;
	Запрос  = Новый Запрос;
	Индекс  = 0;

	Для Каждого КлючЗначение Из УсловияПоиска Цикл
		Индекс = Индекс + 1;
		ИмяПараметра = "Парам" + Индекс;
		Условия.Добавить(КлючЗначение.Ключ + " = &" + ИмяПараметра);
		Запрос.УстановитьПараметр(ИмяПараметра, КлючЗначение.Значение);
	КонецЦикла;

	Запрос.Текст = "ВЫБРАТЬ Ссылка ИЗ Справочник." + ИмяСправочника + " ГДЕ " + СтрСоединить(Условия, " И ");

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

// Возвращает текстовое значение для реквизита: из колонки файла, если она указана,
// иначе — значение «По умолчанию» (если задано), иначе Неопределено (реквизит не
// заполняется — ни из файла, ни умолчанием). Для ключевых реквизитов и реквизитов
// табличных частей значение «По умолчанию» не используется — там нужна именно колонка файла.
&НаСервере
Функция ПолучитьТекстИсточникаЗначения(СтрокаКарты, СтрокаДанных)

	Если Не ПустаяСтрока(СтрокаКарты.КолонкаФайла) Тогда
		Возврат СтрокаДанных.Получить(СтрокаКарты.КолонкаФайла);
	ИначеЕсли Не ПустаяСтрока(СтрокаКарты.ПоУмолчанию) Тогда
		Возврат СтрокаКарты.ПоУмолчанию;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

// Сравнивает значения всех сопоставленных НЕ-табличных реквизитов найденного элемента
// со значениями из файла (или со значением «По умолчанию», если колонка файла не указана).
// Реквизиты табличных частей не сравниваются (см. design.md, Risks).
&НаСервере
Функция ПолучитьРасхождения(Ссылка, ИмяСправочника, СтрокаДанных)

	Расхождения = Новый Массив;

	Для Каждого СтрокаКарты Из ТаблицаСопоставления Цикл
		Если Не ПустаяСтрока(СтрокаКарты.ИмяТабличнойЧасти) Тогда
			Продолжить;
		КонецЕсли;

		ТекстИсточника = ПолучитьТекстИсточникаЗначения(СтрокаКарты, СтрокаДанных);
		Если ТекстИсточника = Неопределено ИЛИ ПустаяСтрока(ТекстИсточника) Тогда
			Продолжить;
		КонецЕсли;

		ЗначениеИзФайла = РазрешитьЗначение(ИмяСправочника, "", СтрокаКарты.ИмяРеквизита,
			СтрокаКарты.ТипРеквизита, ТекстИсточника);
		Если ЗначениеИзФайла = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ЗначениеВБазе = Ссылка[СтрокаКарты.ИмяРеквизита];

		Если Не РавныЗначения(ЗначениеВБазе, ЗначениеИзФайла, СтрокаКарты.ТипРеквизита) Тогда
			ЭлементРасхождения = Новый Структура;
			ЭлементРасхождения.Вставить("ИмяРеквизита",   СтрокаКарты.ИмяРеквизита);
			ЭлементРасхождения.Вставить("Представление",  СтрокаКарты.Представление);
			ЭлементРасхождения.Вставить("ЗначениеВБазе",   Строка(ЗначениеВБазе));
			ЭлементРасхождения.Вставить("ЗначениеВФайле",  Строка(ЗначениеИзФайла));
			Расхождения.Добавить(ЭлементРасхождения);
		КонецЕсли;
	КонецЦикла;

	Возврат Расхождения;

КонецФункции

&НаСервере
Функция РавныЗначения(А, Б, ТипРеквизита)

	Если ТипРеквизита = "Простой" Тогда
		Возврат СтрСравнить(СокрЛП(Строка(А)), СокрЛП(Строка(Б))) = 0;
	КонецЕсли;

	Возврат А = Б;

КонецФункции

// Преобразует текстовое значение ячейки в значение, готовое для записи/сравнения:
// для ссылочных реквизитов и Родителя — поиск по коду связанного справочника;
// для перечислений — поиск значения перечисления по тексту представления;
// для простых — приведение к типу реквизита (число/дата/булево/строка).
&НаСервере
Функция РазрешитьЗначение(ИмяСправочника, ИмяТабличнойЧасти, ИмяРеквизита, ТипРеквизита, ТекстЗначение)

	Если ТекстЗначение = Неопределено ИЛИ ПустаяСтрока(ТекстЗначение) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЧистыйТип = СтрЗаменить(ТипРеквизита, "ТЧ.", "");

	Если СтрНачинаетсяС(ЧистыйТип, "Ссылка.") Тогда
		Возврат НайтиПоКоду(СтрЗаменить(ЧистыйТип, "Ссылка.", ""), ТекстЗначение);
	ИначеЕсли СтрНачинаетсяС(ЧистыйТип, "Родитель.") Тогда
		Возврат НайтиПоКоду(СтрЗаменить(ЧистыйТип, "Родитель.", ""), ТекстЗначение);
	ИначеЕсли СтрНачинаетсяС(ЧистыйТип, "Перечисление.") Тогда
		Возврат НайтиЗначениеПеречисления(СтрЗаменить(ЧистыйТип, "Перечисление.", ""), ТекстЗначение);
	КонецЕсли;

	ОписаниеТипов = ПолучитьОписаниеТиповРеквизита(ИмяСправочника, ИмяТабличнойЧасти, ИмяРеквизита);
	Возврат ПривестиПростоеЗначение(ОписаниеТипов, ТекстЗначение);

КонецФункции

// Ищет значение перечисления, текстовое представление которого совпадает с ТекстЗначение
// (без учёта регистра и пробелов по краям). Возвращает Неопределено, если не найдено.
&НаСервере
Функция НайтиЗначениеПеречисления(ИмяПеречисления, ТекстЗначение)

	МенеджерПеречисления = Перечисления[ИмяПеречисления];

	Для Каждого ЗначениеПеречисления Из МенеджерПеречисления Цикл
		Если СтрСравнить(СокрЛП(Строка(ЗначениеПеречисления)), СокрЛП(ТекстЗначение)) = 0 Тогда
			Возврат ЗначениеПеречисления;
		КонецЕсли;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

&НаСервере
Функция НайтиПоКоду(ИмяСвязанногоСправочника, Код)

	МенеджерСправочника = Справочники[ИмяСвязанногоСправочника];
	Ссылка = МенеджерСправочника.НайтиПоКоду(СокрЛП(Код));

	Если Ссылка = Неопределено ИЛИ Ссылка.Пустая() Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Ссылка;

КонецФункции

&НаСервере
Функция ПолучитьОписаниеТиповРеквизита(ИмяСправочника, ИмяТабличнойЧасти, ИмяРеквизита)

	МетаОбъект = Метаданные.Справочники.Найти(ИмяСправочника);

	Если ПустаяСтрока(ИмяТабличнойЧасти) Тогда
		Если ИмяРеквизита = "Код" Тогда
			Возврат МетаОбъект.СтандартныеРеквизиты.Код.Тип;
		ИначеЕсли ИмяРеквизита = "Наименование" Тогда
			Возврат МетаОбъект.СтандартныеРеквизиты.Наименование.Тип;
		КонецЕсли;
		Возврат МетаОбъект.Реквизиты.Найти(ИмяРеквизита).Тип;
	КонецЕсли;

	ТабЧасть = МетаОбъект.ТабличныеЧасти.Найти(ИмяТабличнойЧасти);
	Возврат ТабЧасть.Реквизиты.Найти(ИмяРеквизита).Тип;

КонецФункции

// Приведение текста к примитивному типу реквизита. Поддерживаемые форматы дат — ISO (YYYY-MM-DD).
&НаСервере
Функция ПривестиПростоеЗначение(ОписаниеТипов, ТекстЗначение)

	Для Каждого Тип Из ОписаниеТипов.Типы() Цикл
		Если Тип = Тип("Число") Тогда
			Попытка
				Возврат Число(СтрЗаменить(ТекстЗначение, ",", "."));
			Исключение
			КонецПопытки;
		ИначеЕсли Тип = Тип("Дата") Тогда
			Попытка
				Возврат Дата(ТекстЗначение);
			Исключение
			КонецПопытки;
		ИначеЕсли Тип = Тип("Булево") Тогда
			ТекстВРегистре = ВРег(СокрЛП(ТекстЗначение));
			Возврат ТекстВРегистре = "ДА" ИЛИ ТекстВРегистре = "TRUE" ИЛИ ТекстЗначение = "1";
		КонецЕсли;
	КонецЦикла;

	Возврат ТекстЗначение;

КонецФункции

// --- Шаг 2а: создание новых элементов ----------------------------------------------

// Создаёт элементы для всех строк ТаблицыАнализа со статусом «Можно создать» и
// отмеченным флажком «Обработать». Строки данных берутся из заново прочитанного файла
// (Строки), сопоставление по номеру строки = СтрокаФайла. Результат пишется в ТаблицуАнализа.
&НаСервере
Функция СоздатьВыбранныеНаСервере(ИмяСправочникаЗначение, Строки)

	СчётчикСоздано = 0;
	СчётчикОшибок  = 0;

	Для Каждого СтрокаТаблицы Из ТаблицаАнализа Цикл

		Если СтрокаТаблицы.Статус <> "Можно создать" ИЛИ Не СтрокаТаблицы.Обработать Тогда
			Продолжить;
		КонецЕсли;

		Индекс = СтрокаТаблицы.СтрокаФайла - 2;
		Если Индекс < 0 ИЛИ Индекс >= Строки.Количество() Тогда
			Продолжить;
		КонецЕсли;
		СтрокаДанных = Строки[Индекс];

		Попытка
			НовыйОбъект = Справочники[ИмяСправочникаЗначение].СоздатьЭлемент();
			ЗаполнитьОбъектИзСтроки(НовыйОбъект, ИмяСправочникаЗначение, СтрокаДанных, Неопределено);
			НовыйОбъект.Записать();
			СтрокаТаблицы.Статус      = "Создан";
			СтрокаТаблицы.Ключ        = Строка(НовыйОбъект.Ссылка);
			СтрокаТаблицы.Обработать  = Ложь;
			СчётчикСоздано = СчётчикСоздано + 1;
		Исключение
			СтрокаТаблицы.Статус = "Ошибка";
			СтрокаТаблицы.Детали = ОписаниеОшибки() + ПолучитьПодсказкуПохожегоЭлемента(ИмяСправочникаЗначение, НовыйОбъект, Неопределено);
			СчётчикОшибок = СчётчикОшибок + 1;
		КонецПопытки;

	КонецЦикла;

	Возврат "Создано элементов: " + СчётчикСоздано + ". Ошибок: " + СчётчикОшибок;

КонецФункции

// --- Шаг 2б: обновление найденных элементов -----------------------------------------

// Применяет подтверждённые пользователем расхождения для строки файла с данным номером.
// АнализСтроки — свежий результат повторного анализа (уже содержит актуальные Ссылку и
// Расхождения). Обновляет соответствующую строку ТаблицыАнализа. Возвращает
// "Обновлён"/"Пропущен"/"Ошибка".
&НаСервере
Функция ПрименитьОбновлениеНаСервере(НомерСтроки, ИмяСправочникаЗначение, СтрокаДанных, АнализСтроки, ПодтверждённыеРеквизиты)

	НайденныеСтроки = ТаблицаАнализа.НайтиСтроки(Новый Структура("СтрокаФайла", НомерСтроки));
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат "Ошибка";
	КонецЕсли;
	СтрокаТаблицы = НайденныеСтроки[0];

	Если ПодтверждённыеРеквизиты = Неопределено ИЛИ ПодтверждённыеРеквизиты.Количество() = 0 Тогда
		СтрокаТаблицы.Статус     = "Пропущен (расхождения отклонены)";
		СтрокаТаблицы.Обработать = Ложь;
		Возврат "Пропущен";
	КонецЕсли;

	Попытка
		ОбъектБазы = АнализСтроки.Ссылка.ПолучитьОбъект();
		ЗаполнитьОбъектИзСтроки(ОбъектБазы, ИмяСправочникаЗначение, СтрокаДанных, ПодтверждённыеРеквизиты);
		ОбъектБазы.Записать();
		СтрокаТаблицы.Статус     = "Обновлён";
		СтрокаТаблицы.Детали     = СтрСоединить(ПодтверждённыеРеквизиты, ", ");
		СтрокаТаблицы.Обработать = Ложь;
		Возврат "Обновлён";
	Исключение
		СтрокаТаблицы.Статус = "Ошибка";
		СтрокаТаблицы.Детали = ОписаниеОшибки()
			+ ПолучитьПодсказкуПохожегоЭлемента(ИмяСправочникаЗначение, ОбъектБазы, АнализСтроки.Ссылка);
		Возврат "Ошибка";
	КонецПопытки;

КонецФункции

// Если у объекта (не записанного из-за ошибки) заполнено "Наименование" — ищет в базе
// другой элемент с ТОЧНО ТАКИМ ЖЕ наименованием (исключая, при обновлении, сам редактируемый
// элемент). Используется как подсказка при ошибке записи (например, нарушение уникальности
// бизнес-правилом конфигурации) — возможно, нужный элемент уже есть под другим кодом.
&НаСервере
Функция ПолучитьПодсказкуПохожегоЭлемента(ИмяСправочника, Объект, ИсключитьСсылку)

	Если Объект = Неопределено ИЛИ ПустаяСтрока(Объект.Наименование) Тогда
		Возврат "";
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка, Код ИЗ Справочник." + ИмяСправочника + " ГДЕ Наименование = &Наименование";
	Если ИсключитьСсылку <> Неопределено Тогда
		Запрос.Текст = Запрос.Текст + " И Ссылка <> &ИсключитьСсылку";
		Запрос.УстановитьПараметр("ИсключитьСсылку", ИсключитьСсылку);
	КонецЕсли;
	Запрос.УстановитьПараметр("Наименование", Объект.Наименование);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда
		Возврат "";
	КонецЕсли;

	Возврат " Возможно, элемент с таким же наименованием уже есть в базе: код """ + Выборка.Код
		+ """ (" + Строка(Выборка.Ссылка) + "). Укажите «Код» как ключ поиска и используйте «Обновить»"
		+ " вместо «Создать».";

КонецФункции

// Заполняет объект (новый или полученный для изменения) значениями из строки данных.
// Если ОграничитьРеквизитами задан (массив имён) — заполняются только перечисленные реквизиты
// (используется при частичном подтверждении расхождений). Иначе заполняются все сопоставленные,
// включая табличные части (только для новых элементов — см. design.md, Non-Goals).
&НаСервере
Процедура ЗаполнитьОбъектИзСтроки(Объект, ИмяСправочника, СтрокаДанных, ОграничитьРеквизитами)

	Для Каждого СтрокаКарты Из ТаблицаСопоставления Цикл

		Если Не ПустаяСтрока(СтрокаКарты.ИмяТабличнойЧасти) Тогда
			Продолжить;
		КонецЕсли;

		Если ОграничитьРеквизитами <> Неопределено
				И ОграничитьРеквизитами.Найти(СтрокаКарты.ИмяРеквизита) = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ТекстИсточника = ПолучитьТекстИсточникаЗначения(СтрокаКарты, СтрокаДанных);
		Если ТекстИсточника = Неопределено Тогда
			Продолжить; // нет ни колонки файла, ни значения по умолчанию — реквизит остаётся незаполненным
		КонецЕсли;

		Значение = РазрешитьЗначение(ИмяСправочника, "", СтрокаКарты.ИмяРеквизита,
			СтрокаКарты.ТипРеквизита, ТекстИсточника);
		Если Значение <> Неопределено Тогда
			Объект[СтрокаКарты.ИмяРеквизита] = Значение;
		КонецЕсли;

	КонецЦикла;

	Если ОграничитьРеквизитами = Неопределено Тогда
		ЗаполнитьТабличныеЧасти(Объект, ИмяСправочника, СтрокаДанных);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТабличныеЧасти(Объект, ИмяСправочника, СтрокаДанных)

	ИменаТЧ = Новый Соответствие;
	Для Каждого СтрокаКарты Из ТаблицаСопоставления Цикл
		Если ПустаяСтрока(СтрокаКарты.ИмяТабличнойЧасти) ИЛИ ПустаяСтрока(СтрокаКарты.КолонкаФайла) Тогда
			Продолжить;
		КонецЕсли;
		ИменаТЧ.Вставить(СтрокаКарты.ИмяТабличнойЧасти, Истина);
	КонецЦикла;

	Для Каждого Эл Из ИменаТЧ Цикл

		ИмяТЧ = Эл.Ключ;
		СтрокиРеквизитовТЧ = ТаблицаСопоставления.НайтиСтроки(Новый Структура("ИмяТабличнойЧасти", ИмяТЧ));

		МаксКоличество = 0;
		Списки = Новый Соответствие;

		Для Каждого СтрокаРеквТЧ Из СтрокиРеквизитовТЧ Цикл
			Если ПустаяСтрока(СтрокаРеквТЧ.КолонкаФайла) Тогда
				Продолжить;
			КонецЕсли;
			ТекстСписком = СтрокаДанных.Получить(СтрокаРеквТЧ.КолонкаФайла);
			Если ТекстСписком = Неопределено ИЛИ ПустаяСтрока(ТекстСписком) Тогда
				СписокЗначений = Новый Массив;
			Иначе
				СписокЗначений = СтрРазделить(ТекстСписком, ";", Ложь);
			КонецЕсли;
			Списки.Вставить(СтрокаРеквТЧ.ИмяРеквизита, СписокЗначений);
			Если СписокЗначений.Количество() > МаксКоличество Тогда
				МаксКоличество = СписокЗначений.Количество();
			КонецЕсли;
		КонецЦикла;

		Для Индекс = 0 По МаксКоличество - 1 Цикл
			НоваяСтрокаТЧ = Объект[ИмяТЧ].Добавить();
			Для Каждого СтрокаРеквТЧ Из СтрокиРеквизитовТЧ Цикл
				СписокЗначений = Списки.Получить(СтрокаРеквТЧ.ИмяРеквизита);
				Если СписокЗначений = Неопределено ИЛИ СписокЗначений.Количество() <= Индекс Тогда
					Продолжить;
				КонецЕсли;
				ТекстЭлемента = СокрЛП(СписокЗначений[Индекс]);
				Если ПустаяСтрока(ТекстЭлемента) Тогда
					Продолжить;
				КонецЕсли;
				Значение = РазрешитьЗначение(ИмяСправочника, ИмяТЧ, СтрокаРеквТЧ.ИмяРеквизита,
					СтрокаРеквТЧ.ТипРеквизита, ТекстЭлемента);
				Если Значение <> Неопределено Тогда
					НоваяСтрокаТЧ[СтрокаРеквТЧ.ИмяРеквизита] = Значение;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти
