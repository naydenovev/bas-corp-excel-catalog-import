#Область ОбработчикиСобытийФормы

Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ИсходныеРасхождения = Параметры.Расхождения;
	Если ИсходныеРасхождения = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого СтрокаИсточник Из ИсходныеРасхождения Цикл
		НоваяСтрока = Расхождения.Добавить();
		НоваяСтрока.СтрокаФайла     = СтрокаИсточник.СтрокаФайла;
		НоваяСтрока.Элемент         = СтрокаИсточник.Элемент;
		НоваяСтрока.ИмяРеквизита    = СтрокаИсточник.ИмяРеквизита;
		НоваяСтрока.Представление   = СтрокаИсточник.Представление;
		НоваяСтрока.ЗначениеВБазе   = СтрокаИсточник.ЗначениеВБазе;
		НоваяСтрока.ЗначениеВФайле  = СтрокаИсточник.ЗначениеВФайле;
		НоваяСтрока.Применить       = Истина;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПрименитьВыбранныеВыполнить(Команда)

	ОтмеченныеЗаписи = Новый Массив;
	Для Каждого Строка Из Расхождения Цикл
		Если Строка.Применить Тогда
			Запись = Новый Структура("СтрокаФайла, ИмяРеквизита", Строка.СтрокаФайла, Строка.ИмяРеквизита);
			ОтмеченныеЗаписи.Добавить(Запись);
		КонецЕсли;
	КонецЦикла;

	Закрыть(ОтмеченныеЗаписи);

КонецПроцедуры

&НаКлиенте
Процедура ПропуститьЭлементВыполнить(Команда)

	Закрыть(Неопределено);

КонецПроцедуры

